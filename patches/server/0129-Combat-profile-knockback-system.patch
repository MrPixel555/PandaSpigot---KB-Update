+    private static volatile File file = new File("knockback", "profile.yml");
+    private static volatile Profile profile = Profile.defaults();
+
+    private KnockbackConfig() {
+    }
+
+    public static synchronized void init(File profileFile) {
+        file = profileFile;
+        try {
+            reload();
+        } catch (Exception ex) {
+            MinecraftServer.LOGGER.error("Could not load knockback combat profile. Default values remain active.", ex);
+        }
+    }
+
+    public static synchronized void reload() throws IOException, InvalidConfigurationException {
+        ensureFile(file);
+
+        YamlConfiguration yaml = new YamlConfiguration();
+        yaml.load(file);
+
+        Profile loaded = Profile.defaults();
+        loaded.type = yaml.getString("KNOCKBACK.TYPE", loaded.type).toUpperCase(Locale.ROOT);
+        if (!"VANILLA".equals(loaded.type)) {
+            throw new InvalidConfigurationException("Unsupported KNOCKBACK.TYPE: " + loaded.type);
+        }
+
+        loadKnockback(yaml, loaded.knockback);
+        loadImpact(yaml, "ENDER-PEARL", loaded.enderPearlImpact);
+        loadImpact(yaml, "SNOWBALL", loaded.snowballImpact);
+        loadImpact(yaml, "EGG", loaded.eggImpact);
+        loadFishingImpact(yaml, loaded.fishingHookImpact);
+        loadArrowImpact(yaml, loaded.arrowImpact);
+        loadImpact(yaml, "EXPLOSION", loaded.explosionImpact);
+
+        loadProjectile(yaml, "ENDER-PEARL", loaded.enderPearlProjectile);
+        loadProjectile(yaml, "SNOWBALL", loaded.snowballProjectile);
+        loadProjectile(yaml, "EGG", loaded.eggProjectile);
+        loadProjectile(yaml, "FISHING-HOOK", loaded.fishingHookProjectile);
+        loadProjectile(yaml, "ARROW", loaded.arrowProjectile);
+        loadProjectile(yaml, "SPLASH-POTION", loaded.splashPotionProjectile);
+
+        validate(loaded);
+        profile = loaded;
+    }
+
+    private static void ensureFile(File file) throws IOException {
+        File parent = file.getParentFile();
+        if (parent != null && !parent.exists() && !parent.mkdirs()) {
+            throw new IOException("Could not create knockback directory: " + parent.getAbsolutePath());
+        }
+        if (!file.exists()) {
+            Files.write(file.toPath(), DEFAULT_CONFIG.getBytes(StandardCharsets.UTF_8));
+        }
+    }
+
+    private static void loadKnockback(YamlConfiguration yaml, KnockbackSettings settings) {
+        String root = "KNOCKBACK.";
+        settings.horizontal = yaml.getDouble(root + "HORIZONTAL", settings.horizontal);
+        settings.vertical = yaml.getDouble(root + "VERTICAL", settings.vertical);
+        settings.verticalLimit = yaml.getDouble(root + "VERTICAL-LIMIT", settings.verticalLimit);
+        settings.horizontalFriction = yaml.getDouble(root + "HORIZONTAL-FRICTION", settings.horizontalFriction);
+        settings.verticalFriction = yaml.getDouble(root + "VERTICAL-FRICTION", settings.verticalFriction);
+        settings.extraHorizontal = yaml.getDouble(root + "EXTRA-HORIZONTAL", settings.extraHorizontal);
+        settings.extraVertical = yaml.getDouble(root + "EXTRA-VERTICAL", settings.extraVertical);
+        settings.resetSprint = yaml.getBoolean(root + "RESET-SPRINT", settings.resetSprint);
+        settings.onePointSevenKnockback = yaml.getBoolean(root + "ONE-POINT-SEVEN-KNOCKBACK", settings.onePointSevenKnockback);
+        settings.slowdown.enabled = yaml.getBoolean(root + "SLOWDOWN.ENABLED", settings.slowdown.enabled);
+        settings.slowdown.value = yaml.getDouble(root + "SLOWDOWN.VALUE", settings.slowdown.value);
+        settings.maxNoDamageTicks.enabled = yaml.getBoolean(root + "MAX-NO-DAMAGE-TICKS.ENABLED", settings.maxNoDamageTicks.enabled);
+        settings.maxNoDamageTicks.value = yaml.getInt(root + "MAX-NO-DAMAGE-TICKS.VALUE", settings.maxNoDamageTicks.value);
+    }
+
+    private static void loadImpact(YamlConfiguration yaml, String key, ImpactSettings settings) {
+        String root = "IMPACT." + key + ".";
+        settings.enabled = yaml.getBoolean(root + "ENABLED", settings.enabled);
+        settings.horizontal = yaml.getDouble(root + "HORIZONTAL", settings.horizontal);
+        settings.vertical = yaml.getDouble(root + "VERTICAL", settings.vertical);
+        settings.horizontalFriction = yaml.getDouble(root + "HORIZONTAL-FRICTION", settings.horizontalFriction);
+        settings.verticalFriction = yaml.getDouble(root + "VERTICAL-FRICTION", settings.verticalFriction);
+        settings.verticalLimit = yaml.getDouble(root + "VERTICAL-LIMIT", settings.verticalLimit);
+        settings.minVerticalLimit = yaml.getDouble(root + "MIN-VERTICAL-LIMIT", settings.minVerticalLimit);
+        settings.straightKnockback = yaml.getBoolean(root + "STRAIGHT-KNOCKBACK", settings.straightKnockback);
+        settings.maxNoDamageTicks.enabled = yaml.getBoolean(root + "MAX-NO-DAMAGE-TICKS.ENABLED", settings.maxNoDamageTicks.enabled);
+        settings.maxNoDamageTicks.value = yaml.getInt(root + "MAX-NO-DAMAGE-TICKS.VALUE", settings.maxNoDamageTicks.value);
+    }
+
